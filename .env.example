# DSP Platform Environment Configuration
# Copy this file to .env and modify values as needed

# ===========================================
# Application Settings
# ===========================================
# JWT Secret for authentication (WAJIB GANTI di production!)
JWT_SECRET=YourSuperSecretJWTKey

# HTTP API Port (Master Server Web Console)
HTTP_PORT=441

# TCP Port for Agent connections
TCP_PORT=447

# ===========================================
# Master Server Configuration
# ===========================================
# Public URL for master server (used by agents)
MASTER_URL=https://master.example.com

# ===========================================
# Agent Configuration (untuk tenant agents)
# ===========================================
# Master server host/IP (diisi di agent)
MASTER_HOST=192.168.1.100

# Master TCP port
MASTER_PORT=447

# Unique name for this agent
AGENT_NAME=agent-kantor-a

# Authentication token (copy dari dashboard Master)
AGENT_TOKEN=your_agent_token_here

# ===========================================
# Database (Optional - untuk target database)
# ===========================================
# Configured via Web Console -> Settings
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dsp_platform
# DB_USER=dsp_user
# DB_PASSWORD=SecurePassword123!

# ===========================================
# Payload Encryption (Application-Level)
# ===========================================
# Enable AES-256-GCM encryption for data payloads
# This is INDEPENDENT from TLS - provides double encryption
PAYLOAD_ENCRYPTION=false

# Encryption key (WAJIB sama di Master dan Agent!)
# Generate dengan: openssl rand -base64 32
ENCRYPTION_KEY=your-32-char-secret-key-here

# ===========================================
# TLS/HTTPS Configuration
# ===========================================
# Enable TLS encryption for all communications
# - HTTPS for Web Console (port 441)
# - TLS for Agent communication (port 447)
TLS_ENABLED=false

# Certificate paths (for Master Server)
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key

# CA Certificate path (for Agent to verify Master)
TLS_CA_PATH=./certs/ca.crt

# Skip certificate verification (DEVELOPMENT ONLY!)
# Set to true for testing with self-signed certificates
# In production, this should ALWAYS be false
TLS_SKIP_VERIFY=false

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FILE=./logs/dsp-platform.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE=30
LOG_COMPRESS=true

# ===========================================
# CORS (Optional)
# ===========================================
CORS_ORIGINS=http://localhost:3000,https://dashboard.example.com

# ===========================================
# TLS Quick Setup Guide
# ===========================================
#
# 1. Generate certificates (Windows):
#    .\deployment\certs\generate-certs.ps1
#
# 2. Generate certificates (Linux):
#    ./deployment/certs/generate-certs.sh
#
# 3. Or let the app auto-generate:
#    Set TLS_ENABLED=true and start Master Server
#    It will auto-generate self-signed certs if not found
#
# 4. Distribute ca.crt to all Agent machines
#    Agents need CA certificate to verify Master Server
#
# To disable TLS: Set TLS_ENABLED=false and restart
# ===========================================
